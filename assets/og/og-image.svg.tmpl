<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <pattern id="scanlines" x="0" y="0" width="1200" height="4" patternUnits="userSpaceOnUse">
      <rect x="0" y="0" width="1200" height="3" fill="transparent"/>
      <rect x="0" y="3" width="1200" height="1" fill="rgba(0,0,0,0.12)"/>
    </pattern>
    <radialGradient id="vignette" cx="50%" cy="50%" r="70%">
      <stop offset="55%" stop-color="transparent"/>
      <stop offset="100%" stop-color="rgba(0,0,0,0.65)"/>
    </radialGradient>
    <filter id="redGlow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="textGlow" x="-5%" y="-5%" width="110%" height="110%">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="#0a0a0a"/>
  <line x1="0" y1="315" x2="1200" y2="315" stroke="#141414" stroke-width="1"/>
  <line x1="600" y1="0" x2="600" y2="630" stroke="#141414" stroke-width="1"/>

  <!-- Left red accent bar -->
  <rect x="0" y="0" width="4" height="630" fill="#c0392b" filter="url(#redGlow)"/>
  <rect x="0" y="0" width="1200" height="1" fill="#222222"/>
  <rect x="0" y="629" width="1200" height="1" fill="#222222"/>

  <!-- Header -->
  <text x="32" y="48" font-family="'Courier New', monospace" font-size="13" fill="#c0392b" letter-spacing="1">adrius@blog:~$</text>
  <text x="173" y="48" font-family="'Courier New', monospace" font-size="13" fill="#333333" letter-spacing="1">cat {{ .File.ContentBaseName }}.md</text>
  <text x="1168" y="48" font-family="'Courier New', monospace" font-size="12" fill="#2e2e2e" letter-spacing="2" text-anchor="end">SECURITY WRITE-UPS</text>
  <rect x="28" y="62" width="1144" height="1" fill="#1a1a1a"/>

  <!-- Tags -->
  {{ $tagX := 32 }}
  {{ range first 5 .Params.tags }}
    {{ $w := add (mul (len .) 8) 22 }}
    <rect x="{{ $tagX }}" y="88" width="{{ $w }}" height="24" fill="transparent" stroke="#c0392b" stroke-width="1"/>
    <text x="{{ add $tagX 11 }}" y="104" font-family="'Courier New', monospace" font-size="11" fill="#c0392b" letter-spacing="0.5">{{ upper . }}</text>
    {{ $tagX = add $tagX (add $w 10) }}
  {{ end }}

  <!-- Date -->
  <text x="1168" y="104" font-family="'Courier New', monospace" font-size="12" fill="#444444" text-anchor="end" letter-spacing="1">{{ dateFormat "2006-01-02" .Date }}</text>

  <!-- Title — safe two-line split using index on words slice -->
  {{ $title := .Title | truncate 60 "..." }}
  {{ $words := split $title " " }}
  {{ $wcount := len $words }}
  {{ $half := div $wcount 2 }}
  {{ if gt $wcount 5 }}
    {{ $l1 := slice }}
    {{ $l2 := slice }}
    {{ range $i, $w := $words }}
      {{ if lt $i $half }}
        {{ $l1 = $l1 | append $w }}
      {{ else }}
        {{ $l2 = $l2 | append $w }}
      {{ end }}
    {{ end }}
    <text x="32" y="288" font-family="'Courier New', monospace" font-size="42" font-weight="bold" fill="#ddd8d0" filter="url(#textGlow)">{{ delimit $l1 " " }}</text>
    <text x="32" y="344" font-family="'Courier New', monospace" font-size="42" font-weight="bold" fill="#ddd8d0" filter="url(#textGlow)">{{ delimit $l2 " " }}</text>
  {{ else }}
    <text x="32" y="316" font-family="'Courier New', monospace" font-size="46" font-weight="bold" fill="#ddd8d0" filter="url(#textGlow)">{{ $title }}</text>
  {{ end }}

  <!-- Red underline -->
  <rect x="32" y="368" width="100" height="3" fill="#c0392b"/>

  <!-- Description — safe two-line split -->
  {{ $desc := .Params.description | default "" | truncate 110 "..." }}
  {{ if $desc }}
    {{ $dwords := split $desc " " }}
    {{ $dwcount := len $dwords }}
    {{ $dhalf := div $dwcount 2 }}
    {{ if gt $dwcount 7 }}
      {{ $dl1 := slice }}
      {{ $dl2 := slice }}
      {{ range $i, $w := $dwords }}
        {{ if lt $i $dhalf }}
          {{ $dl1 = $dl1 | append $w }}
        {{ else }}
          {{ $dl2 = $dl2 | append $w }}
        {{ end }}
      {{ end }}
      <text x="32" y="412" font-family="'Courier New', monospace" font-size="17" fill="#555555" letter-spacing="0.2">{{ delimit $dl1 " " }}</text>
      <text x="32" y="438" font-family="'Courier New', monospace" font-size="17" fill="#555555" letter-spacing="0.2">{{ delimit $dl2 " " }}</text>
    {{ else }}
      <text x="32" y="412" font-family="'Courier New', monospace" font-size="17" fill="#555555" letter-spacing="0.2">{{ $desc }}</text>
    {{ end }}
  {{ end }}

  <!-- Bottom bar -->
  <rect x="0" y="576" width="1200" height="54" fill="#080808"/>
  <rect x="0" y="576" width="1200" height="1" fill="#1a1a1a"/>
  <circle cx="44" cy="603" r="5" fill="#c0392b"/>
  <text x="58" y="608" font-family="'Courier New', monospace" font-size="13" fill="#3a3a3a" letter-spacing="1">ADRIUS.BLOG</text>
  <text x="1168" y="608" font-family="'Courier New', monospace" font-size="13" fill="#3a3a3a" text-anchor="end" letter-spacing="1">{{ math.Round (div (countwords .Content) 200.0) }} MIN READ</text>

  <!-- Scanlines + vignette -->
  <rect width="1200" height="630" fill="url(#scanlines)" opacity="0.8"/>
  <rect width="1200" height="630" fill="url(#vignette)"/>
</svg>
